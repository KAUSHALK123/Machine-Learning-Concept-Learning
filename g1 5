import gensim.downloader as api
import random

model = api.load("glove-wiki-gigaword-100")
seed = "freedom"

if seed in model:
    sims = [w for w, _ in model.most_similar(seed, topn=10)]
    sel = random.sample(sims, 5)  
    print(
        f"In a world defined by {seed}, people found themselves surrounded by concepts like "
        f"{', '.join(sel[:-1])}, and {sel[-1]}. These ideas shaped the way they thought, "
        f"acted, and dreamed. Every step forward in their journey reflected the essence of '{seed}', "
        f"bringing them closer to understanding the true meaning of {sel[0]}."
    )
else:
    print(f"No similar words found for '{seed}'.")

