import numpy as np
from gensim.downloader import load

model = load("fasttext-wiki-news-subwords-300")

print("King Similar Words:")
print(model.most_similar("king", topn=5))

print("\nKing - Man + Woman:")
print(model.most_similar(positive=["king", "woman"], negative=["man"], topn=1))

print("\nParis - France + Italy:")
print(model.most_similar(positive=["paris", "italy"], negative=["france"], topn=1))

sim = np.dot(model["king"], model["queen"]) / (
    np.linalg.norm(model["king"]) * np.linalg.norm(model["queen"])
)
print("\nKing-Queen Similarity:", sim)
print("\nUncle - Man + Woman:")
print(model.most_similar(positive=["uncle", "woman"], negative=["man"], topn=1))
print("\nGood:", [w for w, _ in model.most_similar("good", topn=5)])
print("Bad :", [w for w, _ in model.most_similar("bad", topn=5)])

