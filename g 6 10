import os, re, requests, wikipediaapi # 9
from bs4 import BeautifulSoup
from pydantic import BaseModel

class InstitutionProfile(BaseModel):
    founder: str = "Unknown"
    Established: int = 0
    branches: list[str] = ["Unknown"]
    employee_count: int = 0
    summary: str

def get_data(name: str) -> InstitutionProfile:
    agent = "MyInstitutionInfoBot/1.0 (contact: your-email@example.com)"
    wiki = wikipediaapi.Wikipedia(user_agent=agent, language="en").page(name)
    if not wiki.exists(): raise ValueError(f"Wikipedia page for '{name}' not found.")

    res = requests.get(f"https://en.wikipedia.org/wiki/{name.replace(' ', '_')}", headers={"User-Agent": agent})
    soup = BeautifulSoup(res.text, "html.parser")
    box = soup.find("table", {"class": "infobox"})

    d = {"founder": "Unknown", "Established": 0, "branches": ["Unknown"], "employee_count": 0, "summary": wiki.summary[:300]}

    if box:
        for r in box.find_all("tr"):
            th, td = r.find("th"), r.find("td")
            if th and td:
                k, v = th.text.strip(), td.text.strip()
                if k in ["Founder", "Founders", "Founder(s)"]: d["founder"] = v
                elif k in ["Established", "Founded", "Formation"]:
                    m = re.search(r"\b(18\d{2}|19\d{2}|20\d{2})\b", v)
                    if m: d["Established"] = int(m.group(0))
                elif k in ["Total staff", "Employees", "Staff"]:
                    m = re.search(r"(\d{3,5})", v)
                    if m: d["employee_count"] = int(m.group(0))
                elif k in ["Address", "Location"]: d["branches"] = [v.split(",")[0]]

    if d["founder"] == "Unknown":
        db_res = requests.get(f"https://dbpedia.org/data/{name.replace(' ', '_')}.json", headers={"User-Agent": "MyInstitutionInfoBot/1.0"})
        if db_res.status_code == 200:
            ent = db_res.json().get(f"http://dbpedia.org/resource/{name.replace(' ', '_')}", {})
            if "http://dbpedia.org/ontology/foundedBy" in ent:
                d["founder"] = ent["http://dbpedia.org/ontology/foundedBy"][0]["value"]

    return InstitutionProfile(**d)

if __name__ == "__main__":
    try:
        print(get_data(input("Enter institution name: ")).model_dump_json(indent=2))
    except ValueError as e:
        print(e)















